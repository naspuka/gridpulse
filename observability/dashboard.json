{
  "annotations": { "list": [] },
  "title": "GridPulse — pipeline health",
  "uid": "gridpulse-pipeline-health",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "UTC",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "tags": ["gridpulse"],
  "templating": { "list": [] },
  "_comment": "Imported via Grafana → Dashboards → New → Import → upload JSON. Datasource UIDs (grafanacloud-prom, grafanacloud-logs) are the default names Grafana Cloud assigns; rename if your stack uses different ones.",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Last successful carbon_intensity ingest",
      "description": "How long since the most recent Dagster run for the carbon-intensity asset succeeded. Red if > 90 minutes (we ingest every 30 — three misses).",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "time() - max(pg_stat_user_tables_n_tup_ins{relname=\"carbon_intensity\"} > 0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3600 },
              { "color": "red", "value": 5400 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "API request rate (req/s, last 5m)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=~\".*app.*\"}[5m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Postgres connections (in use vs idle)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "sum by (state) (pg_stat_activity_count)",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Host CPU usage (%)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Host memory available",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "available",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Disk usage (%) — /",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/host\"} * 100 / node_filesystem_size_bytes{mountpoint=\"/host\"})",
          "legendFormat": "/",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "App errors (Loki)",
      "description": "Tails the `app` container's stdout for ERROR / Traceback lines.",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "{service=\"app\"} |~ \"(?i)error|traceback|exception\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Dagster daemon — last 50 lines",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "{service=\"dagster-daemon\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
