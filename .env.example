# Copy this to `.env` and fill in real values. `.env` is gitignored.

# ----- Postgres (hot store + Iceberg catalog) -----
POSTGRES_USER=gridpulse
POSTGRES_PASSWORD=changeme
POSTGRES_DB=gridpulse
# DATABASE_URL is what app/dagster read. Service name `postgres` works inside Compose;
# use `localhost` if you run python in a venv against a containerised db.
DATABASE_URL=postgresql://gridpulse:changeme@postgres:5432/gridpulse

# ----- Cloudflare R2 (lakehouse + backups) -----
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=gridpulse-lake

# ----- Iceberg catalog (uses same Postgres, separate schema) -----
ICEBERG_CATALOG_URI=postgresql://gridpulse:changeme@postgres:5432/gridpulse

# ----- External APIs -----
# Carbon Intensity API: no auth.
# Octopus Energy: no auth for tariff data.
NESO_API_TOKEN=

# ----- Observability -----
# Sentry — find DSN in: sentry.io → Project Settings → Client Keys (DSN).
# Leave blank locally; the SDK init is a no-op without a DSN.
SENTRY_DSN=
SENTRY_TRACES_RATE=0.0

# Healthchecks.io — "Slug-based ping URLs" project setting. URL pattern is
# https://hc-ping.com/<PING_KEY>/<slug>. Checks auto-create on first ping.
HEALTHCHECKS_PING_KEY=

GRAFANA_CLOUD_API_KEY=

# ----- Caddy (prod only) -----
# Generate with `docker run --rm caddy:2-alpine caddy hash-password --plaintext '<pw>'`
DAGSTER_BASIC_AUTH_HASH=

# ----- Misc -----
# Git SHA stamped onto /healthz responses; set by CI in prod.
GIT_SHA=dev
ENVIRONMENT=local
