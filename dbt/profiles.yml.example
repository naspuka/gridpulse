# Copy this to profiles.yml (gitignored) for local-venv dev. In Docker images
# (Dagster CI/prod) this file IS used directly — the Dockerfile copies the
# whole dbt/ dir in and we read env vars that the rest of the stack
# already populates (POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB).
#
# DBT_HOST defaults to the docker-compose service name `postgres`. Override
# to `localhost` (or set in your shell) when running dbt directly from a venv
# on your laptop with port-forwarded Postgres.

gridpulse:
  target: dev
  outputs:
    dev:
      type: postgres
      host:     "{{ env_var('DBT_HOST',          'postgres') }}"
      port:     "{{ env_var('DBT_PORT',          '5432') | as_number }}"
      user:     "{{ env_var('POSTGRES_USER',     'gridpulse') }}"
      password: "{{ env_var('POSTGRES_PASSWORD', 'changeme') }}"
      dbname:   "{{ env_var('POSTGRES_DB',       'gridpulse') }}"
      # `schema` here is dbt's _default_ schema; per-folder overrides in
      # dbt_project.yml put models into staging.* and marts.*.
      schema: marts
      threads: 4
      keepalives_idle: 60
      sslmode: prefer
